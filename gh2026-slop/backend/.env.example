# Copy to backend/.env and fill in. All values are optional except the AI key
# (needed only for the dispatcher chatbot).

# --- AI / chatbot: any OpenAI-compatible endpoint (default = OpenRouter) ---
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=
AI_MODEL=anthropic/claude-sonnet-4.5

# --- Data location (defaults to the extracted dataset under ../data) ---
# GRID_DATA_DIR=/abs/path/to/greenhack-2026-ČEPS-dataset/data

# --- Frame preload window (startup warmup) ---
GRID_PRELOAD_START=0
GRID_PRELOAD_FRAMES=48

# --- Alert thresholds ---
GRID_LINE_LOADING_WARN=75
GRID_LINE_LOADING_ALERT=90
GRID_VOLTAGE_WARN_MARGIN=0.01
GRID_N1_OVERLOAD_PCT=100

# --- Chat usage tracing (server-side log of who used the dispatcher chat) ---
# On by default. Set to 0 to disable. The JSONL log defaults to
# backend/chat_traces.jsonl; override the path if you like.
GRID_CHAT_TRACING=1
# GRID_CHAT_TRACE_FILE=/abs/path/to/chat_traces.jsonl
# Secret required to read GET /api/admin/traces. Leave empty to disable that
# endpoint entirely. Set to a long random string in the deployment.
GRID_ADMIN_TOKEN=
